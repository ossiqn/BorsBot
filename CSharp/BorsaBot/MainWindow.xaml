<Window x:Class="BorsaBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BorsaBot.ViewModels"
        Title="BorsaBot v2.0" Height="720" Width="1100"
        Background="#090912" WindowStyle="SingleBorderWindow"
        MinHeight="600" MinWidth="900">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="KartStyle" TargetType="Border">
            <Setter Property="Background" Value="#0F0F1E"/>
            <Setter Property="BorderBrush" Value="#1A1A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="15"/>
        </Style>

        <Style x:Key="BaslikStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#555577"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="DegerStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="GirisStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#0A0A1A"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#2A2A4A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Height" Value="32"/>
        </Style>

        <Style x:Key="EtiketStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#666688"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <Style x:Key="YesilButon" TargetType="Button">
            <Setter Property="Background" Value="#003322"/>
            <Setter Property="Foreground" Value="#00FF88"/>
            <Setter Property="BorderBrush" Value="#00CC66"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#004433"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="KirmizıButon" TargetType="Button" BasedOn="{StaticResource YesilButon}">
            <Setter Property="Background" Value="#330011"/>
            <Setter Property="Foreground" Value="#FF4466"/>
            <Setter Property="BorderBrush" Value="#CC3355"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#440022"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GriButon" TargetType="Button" BasedOn="{StaticResource YesilButon}">
            <Setter Property="Background" Value="#1A1A2A"/>
            <Setter Property="Foreground" Value="#888899"/>
            <Setter Property="BorderBrush" Value="#333344"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <TextBlock Text="BORSA" Foreground="#00FF88" FontSize="32" FontFamily="Consolas" FontWeight="Bold"/>
                <TextBlock Text="BOT" Foreground="#FFFFFF" FontSize="32" FontFamily="Consolas" FontWeight="Bold"/>
                <TextBlock Text=" v2.0" Foreground="#333355" FontSize="20" FontFamily="Consolas" VerticalAlignment="Bottom" Margin="8,0,0,4"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="8" Height="8" Margin="0,0,6,0">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="#FF4466"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Calisiyor}" Value="True">
                                    <Setter Property="Fill" Value="#00FF88"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Text="{Binding Durum}" Foreground="#888899" FontFamily="Consolas" FontSize="13" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource KartStyle}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="TOPLAM TARAMA" Style="{StaticResource BaslikStyle}"/>
                    <TextBlock Text="{Binding ToplamTarama}" Style="{StaticResource DegerStyle}" Foreground="#4488FF"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource KartStyle}" Margin="4,0">
                <StackPanel>
                    <TextBlock Text="TOPLAM ALIS" Style="{StaticResource BaslikStyle}"/>
                    <TextBlock Text="{Binding ToplamAlis}" Style="{StaticResource DegerStyle}" Foreground="#00FF88"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource KartStyle}" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="TAHMINI KAR" Style="{StaticResource BaslikStyle}"/>
                    <TextBlock Text="{Binding ToplamKar}" Style="{StaticResource DegerStyle}" Foreground="#FFD700"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource KartStyle}" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Proses:" Style="{StaticResource EtiketStyle}"/>
                <TextBox Grid.Column="1" Text="{Binding OyunProsesAdi, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource GirisStyle}" Margin="0,0,15,0"/>

                <TextBlock Grid.Column="2" Text="Hiz(ms):" Style="{StaticResource EtiketStyle}"/>
                <TextBox Grid.Column="3" Text="{Binding TaramaHizi, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource GirisStyle}" Margin="0,0,15,0"/>

                <TextBlock Grid.Column="4" Text="Min Kar:" Style="{StaticResource EtiketStyle}"/>
                <TextBox Grid.Column="5" Text="{Binding MinKarMarji, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource GirisStyle}" Margin="0,0,15,0"/>

                <CheckBox Grid.Column="6" Content="AntiDetect" IsChecked="{Binding AntiDetect}"
                          Foreground="#666688" FontFamily="Consolas" VerticalAlignment="Center" Margin="0,0,15,0"/>
                <CheckBox Grid.Column="7" Content="Oto.Sat" IsChecked="{Binding OtomatikSatis}"
                          Foreground="#666688" FontFamily="Consolas" VerticalAlignment="Center" Margin="0,0,0,0"/>

                <Button Grid.Column="9" Content="▶  BASLAT" Style="{StaticResource YesilButon}"
                        Command="{Binding BotBaslatCommand}" IsEnabled="{Binding BaslatButonAktif}" Margin="15,0,8,0"/>
                <Button Grid.Column="10" Content="■  DURDUR" Style="{StaticResource KirmizıButon}"
                        Command="{Binding BotDurdurCommand}" IsEnabled="{Binding DurdurButonAktif}" Margin="0,0,8,0"/>
                <Button Grid.Column="11" Content="CLR" Style="{StaticResource GriButon}"
                        Command="{Binding LogTemizleCommand}"/>
            </Grid>
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource KartStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="ISLEM LOGU" Foreground="#333355" FontFamily="Consolas"
                               FontSize="11" Margin="0,0,0,10"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  x:Name="LogViewer">
                        <ItemsControl ItemsSource="{Binding LogMesajlari}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="12"
                                               Padding="0,1" TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#446644"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                                        <Setter Property="Foreground" Value="#446644"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource KartStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="AKTIF SINYALLER" Foreground="#333355"
                               FontFamily="Consolas" FontSize="11" Margin="0,0,0,10"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding SinyalListesi}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11"
                                               Foreground="#00AA55" Padding="0,2" TextWrapping="Wrap"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>